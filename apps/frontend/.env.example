# API 配置
# 开发环境：留空，使用 Vite 代理
# 生产环境：设置为 Workers URL 或使用 Pages Functions

# 方案 1: 直接使用 Workers URL
VITE_API_BASE_URL=https://openrouter-free-models-api.hz-studio.workers.dev

# 方案 2: 使用自定义域名（推荐）
# VITE_API_BASE_URL=https://api.yourdomain.com

# 方案 3: 留空，使用 Pages Functions 代理（需要配置 WORKERS_API_URL）
# VITE_API_BASE_URL=
