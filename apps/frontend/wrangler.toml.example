# Cloudflare Pages 配置
# 用于 Pages Functions 的环境变量和 Bindings

name = "openrouter-free-models-frontend"
compatibility_date = "2024-01-01"

# Pages Functions 环境变量
[vars]
WORKERS_API_URL = "https://openrouter-free-models-api.hz-studio.workers.dev"

# 如果 Pages Functions 需要访问 D1（当前架构不需要）
# [[d1_databases]]
# binding = "DB"
# database_name = "openrouter-models"
# database_id = "your-database-id"

# 如果 Pages Functions 需要访问 KV（示例）
# [[kv_namespaces]]
# binding = "CACHE"
# id = "your-kv-namespace-id"
