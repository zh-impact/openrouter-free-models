{
  "name": "@openrouter-free-models/free-route-adv",
  "version": "0.1.0",
  "description": "Advanced filtering and routing for OpenRouter free models with multi-condition support, caching, and availability verification",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vitest",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openrouter",
    "free",
    "models",
    "routing",
    "filtering",
    "cache"
  ],
  "author": "OpenRouter Free Models Monitor",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@openrouter-free-models/shared": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
